{
    "mining": {
        "evalue_threshold": 1e-10,
        "kdops_score_margin": 0
    },
    "qc": {
        "hmm_coverage_min": 0.70,
        "length_windows": {
            "Ia": {
                "canonical_min": 300,
                "canonical_max": 450
            },
            "Ib": {
                "canonical_min": 280,
                "canonical_max": 450
            },
            "II": {
                "canonical_min": 320,
                "canonical_max": 600
            }
        },
        "hmm_lengths": {
            "Ia": 355,
            "Ib": 334,
            "II": 471
        },
        "cdhit_identity_phase1": 0.80,
        "cdhit_identity_seeds": 0.60
    },
    "structure_panel": {
        "target_n": 30,
        "allowed_range": [
            20,
            40
        ],
        "quota_default": {
            "Ia": 12,
            "Ib": 5,
            "II": 13
        },
        "quota_flex": 1,
        "quota_floors": {
            "Ia": 8,
            "Ib": 4,
            "II": 8
        },
        "priority": [
            "PDB",
            "AFDB",
            "ESMFold"
        ],
        "core_plddt_min": 70,
        "core_coverage_min": 0.80,
        "anchor_per_subtype": true,
        "stratification_targets": {
            "small_clusters_pct": 0.30,
            "medium_clusters_pct": 0.30,
            "large_clusters_pct": 0.20,
            "small_max_size": 2,
            "medium_max_size": 10
        }
    },
    "core_definition": {
        "pad_residues": 20,
        "lddt_min": "auto_inflection",
        "gap_fraction_max": 0.30,
        "hit_stitching": "auto",
        "note": "lddt_min 由 FoldMason LDDT 分布拐点确定，记录于 QC2"
    },
    "msa": {
        "hmmalign": {
            "strip_insertions": true,
            "strip_method": "esl-alimask --rf-is-mask",
            "fallback_method": "a2m_drop_lowercase"
        },
        "full_length_stitch": {
            "linker_align_method": "mafft_einsi",
            "architecture_scope": "subtype_specific_homogeneous"
        }
    },
    "phylogeny": {
        "bootstrap_replicates": 1000,
        "outgroup_prefix": "KDOPS_",
        "root_model_baseline": "MFP",
        "root_model_site_hetero": "LG+C20+F+G",
        "root_model_site_hetero_alt": "EX_EHO+F+G"
    },
    "dca": {
        "meff_min_main": 3.0,
        "meff_ideal": 5.0,
        "reweight_threshold": 0.8,
        "regularization_le": 16.0,
        "regularization_lh": 0.01,
        "comparison": {
            "downsample_reps": 20,
            "target_meff": "min(group_meff)"
        }
    },
    "af3": {
        "apo_first": true,
        "holo_requires_pocket": true
    },
    "asr": {
        "altall_pp1": 0.80,
        "altall_pp2": 0.20,
        "cross_scenario_required_before_phase5": true,
        "cross_scenario_outputs": [
            "map_consistency",
            "posterior_delta",
            "information_bits"
        ]
    },
    "rooting": {
        "primary_scenarios": [
            "S1_MFP_KDOPS",
            "S2_LGC20_KDOPS",
            "S3_MIDPOINT_INGROUP",
            "S4A_TOP500_PROXY",
            "S4B_FULLSEARCH_PROXY"
        ],
        "optional_scenarios": ["S5_NONREV_ROOTSTRAP_REDUCED"],
        "qc3_dimensions": [
            "provenance",
            "topology_model_sensitivity",
            "root_tie_identity",
            "annotation_sensitivity"
        ],
        "support_main_min_ufboot": 95,
        "support_preferred_min_shalrt": 80,
        "trait_stability_min_scenarios": 2,
        "phase5_unlock_requires_s2_asr": true,
        "s5_trigger_after_s2_repaired_s4": true
    },
    "module_feature_encoding": {
        "n_ext_relaxed": 10,
        "n_ext_strict": 25,
        "insert_relaxed": 1,
        "insert_strict": 5,
        "c_ext_relaxed": 10,
        "c_ext_strict": 25,
        "act_relaxed": 0.001,
        "act_strict": 1e-05,
        "cm_relaxed": 0.001,
        "cm_strict": 1e-05,
        "c_residual_role": "secondary_conditional"
    },
    "manuscript": {
        "claim_tiers": ["root_robust", "root_sensitive", "exploratory"],
        "phase5_max_tier1": 2,
        "phase5_max_tier2": 2
    },
    "metrics": {
        "manifest_path": "results/meta/metrics_manifest.tsv",
        "snapshot_path": "results/meta/progress_snapshot.md"
    }
}
